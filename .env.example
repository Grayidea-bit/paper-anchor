# LLM（OpenAI 相容 API；預設 DeepSeek）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxxx
LLM_CHAT_MODEL=deepseek-chat

# Embedding（可與 chat 不同供應商）
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=sk-xxxx
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Database
DATABASE_URL=postgresql+asyncpg://paper:paper@db:5432/paper_reader

# App
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=50
ANSWER_LANGUAGE=zh-TW
