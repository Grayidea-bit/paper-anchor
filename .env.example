# LLM — NVIDIA NIM（OpenAI 相容 API）
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi-xxxx
LLM_CHAT_MODEL=deepseek-ai/deepseek-v3.1

# Embedding — 同用 NVIDIA NIM（注意：NIM embedding 需帶 input_type 參數，llm.py 已處理）
EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
EMBED_API_KEY=nvapi-xxxx
# 注意：pgvector 索引上限 2000 維，勿選超過的模型
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_DIM=1024

# Database
DATABASE_URL=postgresql+asyncpg://paper:paper@db:5432/paper_reader

# App
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=50
ANSWER_LANGUAGE=zh-TW
